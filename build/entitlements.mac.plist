<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron's V8 engine generates and executes machine code at runtime; -->
  <!-- without JIT it can't function. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- V8 also writes to executable memory pages outside of its JIT mode. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Required to spawn the bundled ffmpeg binary as a child process and -->
  <!-- to load native modules / dylibs that aren't signed by us. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Lets the user grant write access to a folder via the native save -->
  <!-- panel and have the app actually write there. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
